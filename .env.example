# MontageAI development environment
# Copy to .env and customize as needed.

# Backend API base URL (Electron main process reads this at startup)
MONTAGE_BACKEND_URL=http://127.0.0.1:8000

# Shared auth token — must match on both Electron and manually started backends
MONTAGE_AUTH_TOKEN=montage-dev-token

# Port when Electron spawns the backend (development default: 8000)
MONTAGE_PORT=8000

# Set to false when you start the backend manually (connect-only, no spawn)
MONTAGE_AUTO_SPAWN=false
